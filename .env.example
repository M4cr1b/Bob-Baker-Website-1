# n8n Webhook URLs (set these in Vercel Environment Variables)
N8N_ORDER_WEBHOOK=https://your-n8n-instance.com/webhook/your-order-webhook-id
N8N_ADMIN_DATA_WEBHOOK=https://your-n8n-instance.com/webhook/your-admin-data-webhook-id
N8N_UPDATE_STATUS_WEBHOOK=https://your-n8n-instance.com/webhook/your-update-status-webhook-id
N8N_CONTACT_WEBHOOK=https://your-n8n-instance.com/webhook/your-contact-webhook-id
N8N_INVENTORY_WEBHOOK=https://your-n8n-instance.com/webhook/your-inventory-get-webhook
N8N_INVENTORY_UPDATE_WEBHOOK=https://your-n8n-instance.com/webhook/your-inventory-update-webhook

# Admin credentials
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-admin-password
